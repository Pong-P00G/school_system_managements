# Database
DATABASE_URL=postgresql+asyncpg://123:postgres@localhost:5432/school_system_db_v2
DATABASE_URL_SYNC=postgresql://123:postgres@localhost:5432/school_system_db_v2

# App
APP_NAME=School Management System API
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Prometheus
PROMETHEUS_ENABLED=true
